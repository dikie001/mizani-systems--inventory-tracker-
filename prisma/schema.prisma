generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------
// Auth.js Models
// -----------------------------------------

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  role          String          @default("user") // owner, admin, manager, viewer
  status        String          @default("active") // active, pending
  accounts      Account[]
  sessions      Session[]
  
  // Multi-tenancy
  currentWorkspaceId String?
  memberships        WorkspaceMember[]

  // Custom relations
  stockMovements StockMovement[]
  auditLogs      AuditLog[]

  allowGoogleLink Boolean @default(false)
  loginCount      Int     @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workspace {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  businessType  String?
  inventorySize String?
  goals         String[] @default([])
  currency      String   @default("KES")
  
  members       WorkspaceMember[]
  
  // Scoped Data
  categories    Category[]
  products      Product[]
  orders        Order[]
  stockMovements StockMovement[]
  auditLogs     AuditLog[]
  alerts        Alert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String    @default("MEMBER") // OWNER, ADMIN, MEMBER
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@id([identifier, token])
}

// -----------------------------------------
// Inventory Models
// -----------------------------------------

model Category {
  id          String    @id @default(cuid())
  name        String
  products    Product[]
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, name])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String
  description String?
  image       String?
  price       Float
  stock       Int      @default(0)
  minStock    Int      @default(10)
  maxStock    Int      @default(100)
  status      String   @default("in-stock") // in-stock, low-stock, critical

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  orderItems     OrderItem[]
  stockMovements StockMovement[]
  alerts         Alert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, sku])
}

model Alert {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  severity  String   // warning, critical
  status    String   @default("active") // active, dismissed, resolved
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------
// Order Models
// -----------------------------------------

model Order {
  id                 String   @id @default(cuid())
  customer           String
  total              Float
  status             String   @default("pending") // pending, processing, shipped, delivered, cancelled
  payment            String   @default("unpaid") // unpaid, paid, refunded
  cancellationReason String?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------
// Audit & Movement Models
// -----------------------------------------

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  type      String   // Restock, Sale, Transfer
  quantity  Int      // Positive for restock, negative for sale/transfer
  status    String   @default("completed") // completed, pending, processing
  notes     String?  // Additional details or notes about this movement

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  type      String   // create, update, delete, auth, transfer, settings
  ip        String?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

