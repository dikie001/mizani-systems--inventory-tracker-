generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------
// Auth.js Models
// -----------------------------------------

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  role          String          @default("user") // owner, admin, manager, viewer
  status        String          @default("active") // active, pending
  accounts      Account[]
  sessions      Session[]
  // Custom relations
  stockMovements StockMovement[]
  auditLogs      AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@id([identifier, token])
}

// -----------------------------------------
// Inventory Models
// -----------------------------------------

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  description String?
  price       Float
  stock       Int      @default(0)
  minStock    Int      @default(10)
  maxStock    Int      @default(100)
  status      String   @default("in-stock") // in-stock, low-stock, critical

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  orderItems     OrderItem[]
  stockMovements StockMovement[]
  alerts         Alert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alert {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  severity  String   // warning, critical
  status    String   @default("active") // active, dismissed, resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------
// Order Models
// -----------------------------------------

model Order {
  id         String   @id @default(cuid())
  customer   String
  total      Float
  status     String   @default("pending") // pending, processing, shipped, delivered, cancelled
  payment    String   @default("unpaid") // unpaid, paid, refunded

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------
// Audit & Movement Models
// -----------------------------------------

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  type      String   // Restock, Sale, Transfer
  quantity  Int      // Positive for restock, negative for sale/transfer
  status    String   @default("completed") // completed, pending, processing

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  type      String   // create, update, delete, auth, transfer, settings
  ip        String?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
